# ─────────────────────────────────────────────────────────────
#  MARCO MALIK MD — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Bot Identity ──────────────────────────────────────────────
OWNER_NUMBER=923001234567
OWNER_NAME=Marco Malik
BOT_NAME=MARCO MALIK MD
PREFIX=.
BOT_MODE=public

# ── Session ───────────────────────────────────────────────────
SESSION_ID=

# ── AI Keys (optional — free fallbacks built-in) ──────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
REMOVEBG_API_KEY=

# ── Auto Features ─────────────────────────────────────────────
AUTO_REACT=true
REACT_MODE=random
FIXED_EMOJI=❤️
AUTO_READ=true
AUTO_STATUS_VIEW=true
AUTO_STATUS_REPLY=true
STATUS_REPLY_MSG=Seen Your Status 👀 By Marco Malik

# ── Protection ────────────────────────────────────────────────
ANTI_CALL=true
ANTI_DELETE=true
ANTI_LINK=false
ANTI_SPAM=true
VIEW_ONCE=true

# ── Server ────────────────────────────────────────────────────
PORT=3000
